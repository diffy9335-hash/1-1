# ===== МИДЛВАРЫ =====
class ThrottlingMiddleware(BaseMiddleware):
    def __init__(self, slowdown: float = 0.6):
        self.slowdown = slowdown
        self.cooldowns = {}
        super().__init__()

    async def __call__(self, handler: Callable, event: TelegramObject, data: Dict) -> Any:
        if not isinstance(event, CallbackQuery): return await handler(event, data)
        user_id = event.from_user.id
        now = time.time()
        if now - self.cooldowns.get(user_id, 0) < self.slowdown:
            await event.answer("⚠️ Не спамьте кнопками!", show_alert=False)
            return
        self.cooldowns[user_id] = now
        return await handler(event, data)

class GameBlockMiddleware(BaseMiddleware):
    async def __call__(self, handler: Callable, event: TelegramObject, data: Dict) -> Any:
        if not isinstance(event, CallbackQuery): return await handler(event, data)
        user_id = event.from_user.id
        if user_id in IN_GAME_USERS and not event.data.startswith("game:"):
            await event.answer("❌ Вы находитесь в матче! Доиграйте его.", show_alert=True)
            return
        return await handler(event, data)

class SubCheckMiddleware(BaseMiddleware):
    async def __call__(self, handler: Callable, event: TelegramObject, data: Dict) -> Any:
        user_id = event.from_user.id
        try:
            member = await bot.get_chat_member(chat_id=CHANNEL_ID, user_id=user_id)
            if member.status in ['left', 'kicked']:
                text = "⚠️ <b>Для доступа к игре подпишитесь на наш официальный канал!</b>"
                kb = InlineKeyboardMarkup(inline_keyboard=[
                    [InlineKeyboardButton(text="📢 Подписаться", url=f"https://t.me/{CHANNEL_ID[1:]}")],
                    [InlineKeyboardButton(text="🔄 Проверить подписку", callback_data="check_sub")]
                ])
                if isinstance(event, CallbackQuery):
                    await event.message.edit_text(text, reply_markup=kb)
                else:
                    await event.answer(text, reply_markup=kb)
                return
        except TelegramBadRequest as e:
            if "member not found" in str(e):
                text = "⚠️ <b>Для доступа к игре подпишитесь на наш официальный канал!</b>"
                kb = InlineKeyboardMarkup(inline_keyboard=[
                    [InlineKeyboardButton(text="📢 Подписаться", url=f"https://t.me/{CHANNEL_ID[1:]}")],
                    [InlineKeyboardButton(text="🔄 Проверить подписку", callback_data="check_sub")]
                ])
                if isinstance(event, CallbackQuery):
                    await event.message.edit_text(text, reply_markup=kb)
                else:
                    await event.answer(text, reply_markup=kb)
                return
            else:
                logger.error(f"SubCheck Error: {e}")
        except Exception as e:
            logger.error(f"SubCheck Error: {e}")
        return await handler(event, data)

dp.message.outer_middleware(SubCheckMiddleware())
dp.callback_query.outer_middleware(SubCheckMiddleware())
dp.callback_query.outer_middleware(ThrottlingMiddleware())
dp.callback_query.outer_middleware(GameBlockMiddleware())

