def is_admin(user: Union[User, dict, str, int]) -> bool:
    if isinstance(user, dict):
        return user.get("username", "").lower() == ADMIN_USERNAME
    elif hasattr(user, "username"):
        return user.username and user.username.lower() == ADMIN_USERNAME
    elif isinstance(user, str):
        return user.lower() == ADMIN_USERNAME
    elif isinstance(user, int):
        if user in USERS_DB:
            return USERS_DB[user].get("username", "").lower() == ADMIN_USERNAME
        return False
    return False

def load_db():
    global USERS_DB, CLANS_DB
    if os.path.exists(DB_FILE):
        try:
            with open(DB_FILE, "r", encoding="utf-8") as f:
                data = json.load(f)
                USERS_DB = {int(k): v for k, v in data.get("users", {}).items()}
                CLANS_DB = data.get("clans", {})
            logger.info("✅ База загружена")
        except Exception as e:
            logger.error(f"❌ Ошибка загрузки: {e}")
            USERS_DB = {}
            CLANS_DB = {}
    else:
        USERS_DB = {}
        CLANS_DB = {}
        logger.info("📁 Создана новая база")

def save_db():
    data = {"users": USERS_DB, "clans": CLANS_DB}
    try:
        with open(DB_FILE, "w", encoding="utf-8") as f:
            json.dump(data, f, ensure_ascii=False, indent=2)
        logger.info("💾 База сохранена")
    except Exception as e:
        logger.error(f"❌ Ошибка сохранения: {e}")

