EXP_PER_LEVEL = 100

def add_exp(user, amount):
    user["exp"] += amount
    leveled = False
    while user["exp"] >= EXP_PER_LEVEL:
        user["exp"] -= EXP_PER_LEVEL
        user["level"] += 1
        user["skill_points"] += 1
        user["coins"] += user["level"] * 10
        user["crystals"] += 1
        leveled = True
    return leveled

