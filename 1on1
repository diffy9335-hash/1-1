async def timeattack_timer(match_id):
    await asyncio.sleep(90)
    m = ACTIVE_MATCHES.get(match_id)
    if not m:
        return
    if m["stage"] != "finished":
        m["stage"] = "finished"
        user_id = m["p1"]
        user = USERS_DB[user_id]
        goals = m["score"][user_id]
        mmr_gain = goals * 2
        user["mmr"] += mmr_gain
        unlocked, exp_gain = await update_stats_and_quests(user, "time_attack", goals, 0, mmr_gain, False)
        check_quests_by_type(user, "play_time", 1)
        daily_done, weekly_done = check_quest_completion(user)
        res = f"⏱️ <b>Время вышло!</b>\nВы забили {goals} голов!\n🏅 +{exp_gain} опыта, +{mmr_gain} ММР."
        if unlocked:
            res += "\n\n🏆 <b>Новые достижения:</b>\n"
            for ach in unlocked:
                res += f"{ach['icon']} {ach['name']} (+{ach['reward_coins']} монет, +{ach['reward_crystals']} кристаллов)\n"
        if daily_done:
            res += "\n✅ <b>Выполнено ежедневное задание!</b>"
        if weekly_done:
            res += "\n✅ <b>Выполнено недельное задание!</b>"
        await bot.send_message(user_id, res, reply_markup=back_to_main_keyboard())
        IN_GAME_USERS.discard(user_id)
        ACTIVE_MATCHES.pop(match_id, None)

