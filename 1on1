@dp.message(Command("addfriend"))
async def add_friend_cmd(message: Message):
    args = message.text.split()
    if len(args) < 2:
        await message.answer("Использование: /addfriend @username")
        return
    target_username = args[1].replace("@", "")
    target_id = None
    for uid, data in USERS_DB.items():
        if data.get("username") == target_username:
            target_id = uid
            break
    if not target_id:
        await message.answer("❌ Игрок не найден.")
        return
    if target_id == message.from_user.id:
        await message.answer("❌ Нельзя добавить самого себя.")
        return
    user = get_or_create_user(message.from_user.id)
    if target_id in user["friends"]:
        await message.answer("Этот пользователь уже в ваших друзьях.")
        return
    for req in user.get("friend_requests", []):
        if req.get("from_user_id") == target_id:
            await message.answer("Вы уже отправили заявку этому пользователю.")
            return
    if "friend_requests" not in user:
        user["friend_requests"] = []
    user["friend_requests"].append({"from_user_id": target_id, "timestamp": time.time()})
    save_db()
    
    target_user = get_or_create_user(target_id)
    kb = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="✅ Принять", callback_data=f"friend_accept_{message.from_user.id}")],
        [InlineKeyboardButton(text="❌ Отклонить", callback_data=f"friend_decline_{message.from_user.id}")]
    ])
    await bot.send_message(
        target_id,
        f"👤 Пользователь {user['username']} хочет добавить вас в друзья.\n\nПринять заявку?",
        reply_markup=kb
    )
    await message.answer(f"✅ Заявка отправлена пользователю {target_username}.")

@dp.callback_query(F.data.startswith("friend_accept_"))
async def accept_friend(callback: CallbackQuery):
    from_user_id = int(callback.data.split("_")[2])
    user = get_or_create_user(callback.from_user.id)
    found = False
    for req in user.get("friend_requests", []):
        if req.get("from_user_id") == from_user_id:
            found = True
            break
    if not found:
        await callback.answer("❌ Заявка не найдена или уже обработана.", show_alert=True)
        return
    user["friend_requests"] = [req for req in user.get("friend_requests", []) if req.get("from_user_id") != from_user_id]
    if from_user_id not in user["friends"]:
        user["friends"].append(from_user_id)
    from_user = get_or_create_user(from_user_id)
    if callback.from_user.id not in from_user["friends"]:
        from_user["friends"].append(callback.from_user.id)
    save_db()
    await callback.message.edit_text("✅ Заявка принята! Теперь вы друзья.")
    await bot.send_message(from_user_id, f"✅ {user['username']} принял вашу заявку в друзья!")

