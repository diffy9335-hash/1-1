def check_streak(user, target):
    history = user["match_history"][-target:]
    if len(history) < target:
        return False
    return all(m.get("result") == "win" for m in history)

# ===== ММР РАСЧЁТ =====
def calculate_mmr_change(user, opponent, result, goals_scored, goals_conceded):
    if result == "win":
        base = 30
        if goals_scored - goals_conceded >= 2:
            base += 10
        if goals_scored - goals_conceded >= 3:
            base += 10
        diff = opponent.get("mmr", 0) - user["mmr"]
        if diff > 0:
            base += min(diff // 100, 20)
        else:
            base += max(diff // 100, -10)
        sniper_level = user["skills"].get("sniper", 0)
        base += int(sniper_level * 0.5)
    else:
        base = -20
        if goals_conceded - goals_scored >= 2:
            base -= 5
        if goals_conceded - goals_scored >= 3:
            base -= 10
        diff = opponent.get("mmr", 0) - user["mmr"]
        if diff > 0:
            base += min(diff // 100, 15)
        else:
            base += max(diff // 100, -10)
        tough_level = user["skills"].get("tough", 0)
        if tough_level > 0:
            reduction = tough_level * 0.005
            base = int(base * (1 - reduction))
    if user["mmr"] + base < 0:
        base = -user["mmr"]
    return base

