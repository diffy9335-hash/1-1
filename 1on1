@dp.callback_query(F.data == "menu_pvp")
async def start_match_search(callback: CallbackQuery):
    user_id = callback.from_user.id
    user = get_or_create_user(user_id, callback.from_user.username)
    if user.get("banned"):
        return await callback.answer("❌ Вы забанены!", show_alert=True)
    if user["energy"] < 1:
        return await callback.answer("❌ Нет энергии! Восстановите на базе.", show_alert=True)
    if user_id in MATCHMAKING_QUEUE:
        return await callback.answer("⏳ Вы уже ищете соперника!", show_alert=True)

    opponent_id = None
    for q_uid in MATCHMAKING_QUEUE:
        if abs(USERS_DB[q_uid].get("mmr", 0) - user["mmr"]) <= 1000:
            opponent_id = q_uid
            break

    if opponent_id is None:
        MATCHMAKING_QUEUE.append(user_id)
        await callback.message.edit_text(
            "🔍 <b>Поиск соперника поблизости (±1000 ММР)...</b>\n\nОжидаем подключения оппонента.",
            reply_markup=cancel_search_keyboard()
        )
    else:
        MATCHMAKING_QUEUE.remove(opponent_id)
        user["energy"] -= 1
        USERS_DB[opponent_id]["energy"] -= 1
        IN_GAME_USERS.update([opponent_id, user_id])
        await callback.message.edit_text("⚔️ Соперник найден! Поле генерируется...")
        asyncio.create_task(init_game_session(opponent_id, user_id, match_type="pvp"))

