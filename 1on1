def add_xp(user, amount):
    if user["bp_level"] >= 60: return ""
    if user["inventory"]["kit"]:
        amount = int(amount * 1.2)
    user["bp_xp"] += amount
    lvl_up_text = ""
    while user["bp_xp"] >= 20 and user["bp_level"] < 60:
        user["bp_xp"] -= 20
        user["bp_level"] += 1
        coins_reward = user["bp_level"] * 75
        user["coins"] += coins_reward
        user["crystals"] += 1
        premium_text = ""
        if user["is_premium"]:
            vip_coins = coins_reward * 2
            user["coins"] += vip_coins
            user["crystals"] += 1
            user["cups"] += 35
            premium_text = f"\n💎 <b>Бонус VIP+:</b> 💰 +{vip_coins} монет, 💎 +1 Кристалл, 🏆 +35 кубков!"
        lvl_up_text += f"\n\n🎉 <b>НОВЫЙ УРОВЕНЬ БИЛЕТА! ({user['bp_level']}/60)</b>\n🎁 Награда: 💰 +{coins_reward} монет, 💎 +1 Кристалл.{premium_text}"
