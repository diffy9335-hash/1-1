async def update_stats_and_quests(user, result, goals_scored, goals_conceded, mmr_change, is_pvp):
    stats = user["stats"]
    stats["matches"] += 1
    if result == "win":
        stats["wins"] += 1
    else:
        stats["losses"] += 1
    stats["goals"] += goals_scored
    stats["goals_conceded"] += goals_conceded
    stats["total_time"] += 60

    user["match_history"].append({
        "date": datetime.now().isoformat(),
        "result": result,
        "score": f"{goals_scored}-{goals_conceded}",
        "opponent": "бот" if not is_pvp else "игрок",
        "mmr_change": mmr_change
    })
    if len(user["match_history"]) > 20:
        user["match_history"] = user["match_history"][-20:]

    unlocked = check_achievements(user)

    exp_gain = 10 + goals_scored * 2
    if result == "win":
        exp_gain += 15
    add_exp(user, exp_gain)

    if is_pvp:
        check_quests_by_type(user, "play_pvp", 1)
    else:
        check_quests_by_type(user, "play_pve", 1)
    if result == "win":
        check_quests_by_type(user, "win_any", 1)
    check_quests_by_type(user, "score", goals_scored)

    return unlocked, exp_gain

def check_quests_by_type(user, quest_type, amount):
    for q in user.get("daily_quests", []):
        if q.get("type") == quest_type:
            q["current"] = q.get("current", 0) + amount
    for q in user.get("weekly_quests", []):
        if q.get("type") == quest_type:
            q["current"] = q.get("current", 0) + amount

def check_quest_completion(user):
    daily_done = False
    for q in user.get("daily_quests", []):
        if q.get("current", 0) >= q["target"]:
            user["coins"] += q.get("reward_coins", 0)
            user["crystals"] += q.get("reward_crystals", 0)
            if "reward_xp" in q:
                add_exp(user, q["reward_xp"])
            q["current"] = 0
            daily_done = True
    weekly_done = False
    for q in user.get("weekly_quests", []):
        if q.get("current", 0) >= q["target"]:
            user["coins"] += q.get("reward_coins", 0)
            user["crystals"] += q.get("reward_crystals", 0)
            q["current"] = 0
            weekly_done = True
    return daily_done, weekly_done

