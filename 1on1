@dp.message(Command("invite_room"))
async def invite_room_cmd(message: Message):
    args = message.text.split()
    if len(args) < 3:
        await message.answer("Использование: /invite_room @username room_id")
        return
    target_username = args[1].replace("@", "")
    room_id = args[2]
    if room_id not in PRIVATE_ROOMS:
        await message.answer("❌ Комната не найдена.")
        return
    room = PRIVATE_ROOMS[room_id]
    if room["creator"] != message.from_user.id:
        await message.answer("❌ Только создатель комнаты может приглашать.")
        return
    if len(room["players"]) >= 2:
        await message.answer("❌ Комната уже заполнена.")
        return
    target_id = None
    for uid, data in USERS_DB.items():
        if data.get("username") == target_username:
            target_id = uid
            break
    if not target_id:
        await message.answer("❌ Игрок не найден.")
        return
    if target_id in room["players"]:
        await message.answer("❌ Этот игрок уже в комнате.")
        return
    room["invited"].append(target_id)
    await bot.send_message(
        target_id,
        f"🏟 <b>Приглашение в комнату!</b>\n\n"
        f"Игрок {USERS_DB[message.from_user.id]['username']} приглашает вас сыграть товарищеский матч.\n"
        f"Комната: <code>{room_id}</code>\n\n"
        f"Чтобы присоединиться, напишите: /join_room {room_id}"
    )
    await message.answer(f"✅ Приглашение отправлено {target_username}.")

