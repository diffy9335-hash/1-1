    args = message.text.split()
    if len(args) < 2:
        await message.answer("Использование: /upgrade_skill <название>\nДоступно: sniper, wall, leader, runner, tough")
        return
    skill_name = args[1].lower()
    if skill_name not in SKILL_TREE:
        await message.answer("Неизвестный навык.")
        return
    user = get_or_create_user(message.from_user.id)
    if user["skill_points"] < SKILL_TREE[skill_name]["cost_per_level"]:
        await message.answer("Недостаточно очков навыков.")
        return
    if user["skills"][skill_name] >= SKILL_TREE[skill_name]["max_level"]:
        await message.answer("Навык уже максимального уровня.")
        return
    user["skill_points"] -= SKILL_TREE[skill_name]["cost_per_level"]
    user["skills"][skill_name] += 1
    await message.answer(f"✅ Навык '{SKILL_TREE[skill_name]['name']}' повышен до уровня {user['skills'][skill_name]}!")

