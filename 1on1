async def init_game_session(p1, p2, match_type="pvp"):
    u1 = USERS_DB[p1]
    is_bot = (p2 == "ai_bot")
    
    if is_bot:
        if match_type == "career":
            bot_name = f"🤖 Босс Лиги {u1['career_stage']}"
        elif match_type == "tourney":
            bot_name = f"🤖 Турнирный ИИ (Этап {u1['tourney_wins'] + 1})"
        else:
            bot_name = "🤖 Робот-Вратарь v2.0"
    else:
        bot_name = "👤 " + USERS_DB[p2]["username"]
    
    u2 = {"username": bot_name, "mmr": 0} if is_bot else USERS_DB[p2]
    match_id = f"g_{p1}_{random.randint(1000, 9999)}"
    msg1 = await send_safely(p1, f"🏟 <b>Матч начинается!</b>\n\nПротивник: 👤 <b>{u2['username']}</b>")
    msg2 = None if is_bot else await send_safely(p2, f"🏟 <b>Матч начинается!</b>\n\nПротивник: 👤 <b>{u1['username']}</b>")
    ACTIVE_MATCHES[match_id] = {
        "p1": p1, "p2": p2, "is_bot": is_bot, "match_type": match_type,
        "p1_name": u1["username"], "p2_name": u2["username"],
        "score": {p1: 0, p2: 0}, "round": 1, "stage": "atk_choosing",
        "attacker": p1, "defender": p2, "atk_choice": None,
        "ult_used": {p1: False, p2: False if is_bot else False},
        "messages": {p1: msg1.message_id if msg1 else None, p2: msg2.message_id if msg2 else None}
    }
    await asyncio.sleep(1.5)
    await execute_match_turn(match_id)

async def execute_match_turn(match_id):
    m = ACTIVE_MATCHES.get(match_id)
    if not m:
        return
    atk, dfn = m["attacker"], m["defender"]
    r = m["round"]
    if m["is_bot"] and atk == "ai_bot":
        m["atk_choice"] = random.choice(["left", "center", "right"])
        if not m["ult_used"]["ai_bot"] and random.random() < 0.3:
            m["atk_choice"] = "ult"
            m["ult_used"]["ai_bot"] = True
        m["stage"] = "def_guessing"
        def_text = f"<b>Раунд {r}</b>\n\n🤖 Противник нанес скрытый удар! Куда прыгаем?"
        await bot.edit_message_text(chat_id=dfn, message_id=m["messages"][dfn], text=def_text, reply_markup=game_choice_keyboard(match_id, "def", not m["ult_used"][dfn]))
        return
    atk_text = f"<b>Раунд {r}</b>\n\n🔥 Ваша <b>АТАКУЮЩАЯ</b> очередь. Куда пробьем?"
    try:
        await bot.edit_message_text(chat_id=atk, message_id=m["messages"][atk], text=atk_text, reply_markup=game_choice_keyboard(match_id, "atk", not m["ult_used"][atk]))
    except Exception:
        pass
    if not m["is_bot"]:
        def_text = f"<b>Раунд {r}</b>\n\n🧤 Вы на <b>ЗАЩИТЕ</b>. Ожидайте действий форварда..."
        try:
            await bot.edit_message_text(chat_id=dfn, message_id=m["messages"][dfn], text=def_text)
        except Exception:
            pass

@dp.callback_query(F.data.startswith("game:"))
async def process_game_callbacks(callback: CallbackQuery):
    data = callback.data.split(":")
    match_id, role, choice = data[1], data[2], data[3]
    m = ACTIVE_MATCHES.get(match_id)
    if not m:
        return await callback.answer("Матч завершен.", show_alert=True)
    
    if m.get("match_type") == "timeattack":
        uid = callback.from_user.id
        if uid != m["attacker"]:
            return await callback.answer("Это не ваш матч.", show_alert=True)
        if m["stage"] == "atk_choosing":
            if choice == "ult":
                m["ult_used"][uid] = True
            m["atk_choice"] = choice
            m["stage"] = "def_guessing"
            await callback.message.edit_text("⚽ Вы пробили! Вратарь в прыжке...")
            bot_choice = random.choice(["left", "center", "right"])
            user = USERS_DB[uid]
            atk, _ = get_effective_stats(user)
            sniper_bonus = user["skills"].get("sniper", 0) * 0.005
            chance = min(0.9, 0.3 + atk / 400 + sniper_bonus)
            is_goal = False
            if choice == "ult":
                if bot_choice == "center":
                    is_goal = False
                else:
                    is_goal = True
            else:
                if choice != bot_choice:
                    is_goal = True
                else:
                    if random.random() < chance:
                        is_goal = True
            if is_goal:
                m["score"][uid] += 1
                await callback.message.edit_text("🔥 ГОЛ! Мяч в сетке! ⚽")
            else:
                await callback.message.edit_text("🧤 СЕЙВ! Вратарь отбил!")
            m["stage"] = "atk_choosing"
            m["atk_choice"] = None
            if time.time() - m.get("time_start", time.time()) < m.get("time_limit", 90):
                await asyncio.sleep(1)
                await bot.send_message(
                    uid,
                    "⏱️ Продолжаем! Выберите направление следующего удара:",
                    reply_markup=game_choice_keyboard(match_id, "atk", True)
                )
            else:
                pass
        await callback.answer()
        return
    
    atk, dfn = m["attacker"], m["defender"]
    uid = callback.from_user.id
    
    if role == "atk" and m["stage"] == "atk_choosing" and uid == atk:
        if choice == "ult":
            m["ult_used"][atk] = True
        m["atk_choice"] = choice
        m["stage"] = "def_guessing"
        await callback.message.edit_text("⚽ Вы пробили! Ждем реакцию вратаря...")
        if m["is_bot"]:
            u_atk, _ = get_effective_stats(USERS_DB[m["p1"]])
            base_fail_chance = 0.2
            if m["match_type"] == "career":
                base_fail_chance = max(0.05, 0.4 - (USERS_DB[m["p1"]]["career_stage"] * 0.05))
            elif m["match_type"] == "tourney":
                base_fail_chance = max(0.1, 0.3 - (USERS_DB[m["p1"]]["tourney_wins"] * 0.1))
            sniper_bonus = USERS_DB[m["p1"]]["skills"].get("sniper", 0) * 0.005
            bot_fail_chance = min(0.7, base_fail_chance + (u_atk / 800) + sniper_bonus)
            if random.random() < bot_fail_chance:
                bot_choice = random.choice([c for c in ["left", "center", "right"] if c != choice])
            else:
                bot_choice = choice
            await callback.message.edit_text("⏳ <i>Мяч летит в сторону ворот... Вратарь в прыжке!</i>")
            await asyncio.sleep(1.5)
            await handle_round_resolution(match_id, m["atk_choice"], bot_choice)
        else:
            def_text = f"<b>Раунд {m['round']}</b>\n\n⚡ Нападающий бьет! Твой прыжок:"
            await bot.edit_message_text(chat_id=dfn, message_id=m["messages"][dfn], text=def_text, reply_markup=game_choice_keyboard(match_id, "def", not m["ult_used"][dfn]))
    elif role == "def" and m["stage"] == "def_guessing" and uid == dfn:
        if choice == "ult":
            m["ult_used"][dfn] = True
        if not m["is_bot"]:
            await bot.edit_message_text(chat_id=atk, message_id=m["messages"][atk], text="⏳ <i>Мяч летит в сторону ворот... Вратарь в прыжке!</i>")
        await callback.message.edit_text("⏳ <i>Мяч летит в сторону ворот... Вы в прыжке!</i>")
        await asyncio.sleep(1.5)
        await handle_round_resolution(match_id, m["atk_choice"], choice)
    await callback.answer()

async def handle_round_resolution(match_id, atk_choice, def_choice):
    m = ACTIVE_MATCHES.get(match_id)
    if not m:
        return
    p1, p2 = m["p1"], m["p2"]
    is_goal = False
    details = ""
    wall_level = 0
    if not m["is_bot"]:
        wall_level = USERS_DB[m["defender"]]["skills"].get("wall", 0)
    wall_bonus = wall_level * 0.005
    
    if atk_choice == "ult" and def_choice == "center":
        is_goal = False
        details = "💥 Крученый удар отражен по центру железными руками вратаря!"
    elif atk_choice == "ult":
        is_goal = True
        details = "🔥 Крученый удар! Мяч поменял траекторию и вонзился в сетку!"
    elif def_choice == "ult":
        is_goal = False
        details = "🐆 Прыжок пантеры! Голкипер закрыл всю площадь ворот!"
    else:
        if atk_choice == def_choice:
            if not m["is_bot"]:
                a_atk, _ = get_effective_stats(USERS_DB[m["attacker"]])
                _, d_dfn = get_effective_stats(USERS_DB[m["defender"]])
                breakthrough_chance = max(0.05, 0.3 - wall_bonus)
                if a_atk > d_dfn + 40 and random.random() < breakthrough_chance:
                    is_goal = True
                    details = "💥 Вратарь угадал, но АТАКА была слишком мощной — мяч прошил руки!"
                else:
                    is_goal = False
                    details = f"🧤 СЕЙВ! Вратарь берет мяч в углу: {get_dir_name(def_choice)}"
            else:
                is_goal = False
                details = "🧤 Противник совершает уверенный сейв!"
        else:
            is_goal = True
            details = f"🔥 ГОЛ! Мяч улетел в {get_dir_name(atk_choice)}, а кипер прыгнул в {get_dir_name(def_choice)}"
    if is_goal:
        m["score"][m["attacker"]] += 1
    res_msg = f"{details}\n\n📊 Счет: {m['p1_name']} [{m['score'][p1]}] : [{m['score'][p2]}] {m['p2_name']}"
    m["round"] += 1
    if m["round"] > 6 and m['score'][p1] != m['score'][p2]:
        winner = p1 if m["score"][p1] > m["score"][p2] else p2
        await finish_game_session(match_id, winner)
    else:
        m["attacker"], m["defender"] = m["defender"], m["attacker"]
        m["stage"] = "atk_choosing"
        m["atk_choice"] = None
        await send_safely(p1, res_msg)
        if not m["is_bot"]:
            await send_safely(p2, res_msg)
        await asyncio.sleep(2)
        await execute_match_turn(match_id)

async def finish_game_session(match_id, winner):
