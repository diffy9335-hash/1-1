@dp.callback_query(F.data.startswith("chest_"))
async def handle_chest_actions(callback: CallbackQuery):
    user = get_or_create_user(callback.from_user.id)
    data = callback.data.split("_")
    action = data[1]
    idx = int(data[2])

    if idx >= len(user["chests"]):
        await callback.answer("❌ Сундук не найден.", show_alert=True)
        await show_chests(callback)
        return

    chest = user["chests"][idx]
    now = time.time()
    tier = chest["tier"]
    info = CHEST_TIERS[tier]

    if action == "start":
        if chest.get("unlock_at") is not None:
            await callback.answer("Этот сундук уже открывается.", show_alert=True)
            await show_chests(callback)
            return

        for c in user["chests"]:
            if c.get("unlock_at") is not None and c["unlock_at"] > now:
                await callback.answer("❌ Одновременно можно открывать только один сундук!", show_alert=True)
                await show_chests(callback)
                return

        duration = get_chest_unlock_seconds(tier)
        chest["unlock_at"] = now + duration
        save_db()
        await callback.answer(f"⏳ Открытие начато! Оно займёт {info['unlock_hours']} ч.", show_alert=True)
        await show_chests(callback)

    elif action == "open":
        if chest.get("unlock_at") is None:
            await callback.answer("❌ Сначала начните открытие сундука!", show_alert=True)
            await show_chests(callback)
            return
        if now < chest["unlock_at"]:
            await callback.answer("⏳ Время ещё не вышло!", show_alert=True)
            await show_chests(callback)
            return

        rewards = get_chest_rewards(tier)
        user["coins"] += rewards["coins"]
        user["crystals"] += rewards["crystals"]
        add_exp(user, rewards["exp"])
        user["chests"].pop(idx)
        save_db()

        await callback.answer(
            f"🎉 {info['emoji']} {info['name']} сундук открыт!\n"
            f"💰 +{rewards['coins']} монет\n"
            f"💎 +{rewards['crystals']} кристаллов\n"
            f"⚡ +{rewards['exp']} опыта",
            show_alert=True
        )
        await show_chests(callback)

    elif action == "rush":
        if chest.get("unlock_at") is None:
            await callback.answer("❌ Сначала начните открытие сундука!", show_alert=True)
            await show_chests(callback)
            return
        if now >= chest["unlock_at"]:
            await callback.answer("Сундук уже готов к открытию! Используйте 'Открыть'.", show_alert=True)
            await show_chests(callback)
            return

        remains = int(chest["unlock_at"] - now)
        cost = max(1, remains // 60)
        if user["crystals"] < cost:
            await callback.answer(f"❌ Недостаточно кристаллов! Нужно {cost} 💎", show_alert=True)
            await show_chests(callback)
            return

        user["crystals"] -= cost
        chest["unlock_at"] = now
        save_db()
        await callback.answer(f"✅ Сундук ускорен за {cost} кристаллов! Теперь его можно открыть.", show_alert=True)
        await show_chests(callback)

