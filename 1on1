    if message.from_user.id not in verify_cmd.cache:
        return
    if int(message.text) == verify_cmd.cache[message.from_user.id]:
        user = get_or_create_user(message.from_user.id)
        user["verified"] = True
        del verify_cmd.cache[message.from_user.id]
        await message.answer("✅ Вы успешно верифицированы! Теперь у вас есть значок ✅ в профиле.")
    else:
        await message.answer("❌ Неверный код. Попробуйте снова /verify")

